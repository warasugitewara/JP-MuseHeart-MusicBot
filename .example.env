########################################################################
### 注意: このファイルを使用するには .env にリネームしてください      ###
### 値にスペースが含まれる場合は必ずクォートで囲んでください！        ###
########################################################################

##########################################################################################################
### ボットのトークン（必須）                                                                             ###
### 補足: 複数のトークンをスペース区切りで同じ変数に入れるか、                                          ###
###       任意の名前（英数字/アンダースコアのみ）の変数を追加してトークンを設定することで              ###
###       ボットを複数起動できます。                                                                    ###
###                                                                                                    ###
### 例（1トークン）:                                                                                   ###
### TOKEN='bbbbbbbbbcccDASDSAdeefff.gggghhhhiiii'                                                      ###
### MYBOT='asdsadbbc2cDASDSAdeef3ff.adew234411ax'                                                      ###
###                                                                                                    ###
### 例（複数トークンをスペース区切りで1つの変数に）:                                                   ###
### TOKEN='aaabbbbbccccddddeeeefff.gggghhhhiiii aaabbbbb324234dddeeeefff.gggghhhhiiii'                 ###
### MYBOT='bbbbbbbbbcccDASDSAdeefff.gggghhhhiiii 213bbabscccddeeeefff.gggghhhhiiii'                    ###
### COOLBOT='bbbbbbbbbcccDASDSAdeefff.gggghhhhiiii 213bbabscccddeeeefff.gggghhhhiiii'                  ###
##########################################################################################################

# ボットのトークン（複数ある場合はスペース区切り）
TOKEN=''

# ボットのデフォルトプレフィックス
DEFAULT_PREFIX='!!'

# 公開Lavalinkサーバーリストを自動ダウンロードする。
# squarecloud / discloud / repl.it / render の無料プランなど、CPU・RAM・通信量が制限された環境では true を推奨。
AUTO_DOWNLOAD_LAVALINK_SERVERLIST=false

# MongoDBのURL（未設定の場合はJSONファイルをデータベースとして使用）。取得方法: https://github.com/zRitsu/MuseHeart-MusicBot/wiki/MongoDB-Tutorial
MONGO=''

# アクティブなプレイヤーのセッションデータをMongoDBに保存する（MONGOの設定が必要）。
# false の場合はローカルデータベース（JSON）に保存されます。
PLAYER_SESSIONS_MONGODB=false

# Sourceを公開しているホストで機密データが保存される可能性がある場合に警告を表示する。
SENSITIVE_INFO_WARN=true

##################################################
### 音楽システム - Spotifyサポート              ###
##################################################

# 自動取得される訪問者キーの代わりに独自のAPIキーを使用する。
# 取得方法のチュートリアル: https://github.com/zRitsu/MuseHeart-MusicBot/wiki/Spotify-Keys
SPOTIFY_CLIENT_ID=''
SPOTIFY_CLIENT_SECRET=''

# Spotifyプレイリストで最初の100曲以降を取得する追加ページ数の上限。
# 1ページあたり100曲追加で、ページごとにAPI追加リクエストが発生するため増やしすぎ注意。
SPOTIFY_PLAYLIST_EXTRA_PAGE_LIMIT=0

###############
### Intents ###
###############
BANS_INTENT='false'
DM_MESSAGES_INTENT='false'
DM_REACTIONS_INTENT='false'
DM_TYPING_INTENT='false'
GUILD_MESSAGES_INTENT='true'
GUILD_REACTIONS_INTENT='false'
GUILD_SCHEDULED_EVENTS_INTENT='false'
GUILD_TYPING_INTENT='false'
EMOJIS_AND_STICKERS_INTENT='true'
INTEGRATIONS_INTENT='true'
INVITES_INTENT='true'
VOICE_STATES_INTENT='true'
WEBHOOKS_INTENT='false'

##########################
### Privileged Intents ###
##########################
PRESENCES_INTENT='false'
MESSAGE_CONTENT_INTENT='true'

##############################
### その他のオプション設定  ###
##############################

# ボットのオーナーとして登録するユーザーID（複数の場合は || 区切り）。
# リストに追加したIDはボットへの完全アクセスが与えられるため取り扱い注意！
OWNER_IDS=''

# 429エラー（Too Many Requests）発生時にボットを強制終了する。
KILL_ON_429=true

# コマンドのクールダウンを有効にする。
# 少人数の身内サーバーのみで使用する場合は false でも可。
# skip等のコマンドを短時間に大量使用するとLavalinkサーバーが音楽プラットフォームのレート制限を受けやすくなるため推奨。
ENABLE_COMMANDS_COOLDOWN=true

# コマンドのログを有効にする。
COMMAND_LOG=false

# サポートサーバーの招待リンク（aboutコマンドやエラー時に表示されます）。
SUPPORT_SERVER=''

# ボット起動時にコマンドを自動同期する。
AUTO_SYNC_COMMANDS=true

# ボットがサーバーに追加・削除された際のログを送信するWebhookのURL。
BOT_ADD_REMOVE_LOG=''

# ボットがサーバーに追加・削除された際のログを送信するチャンネルID。
BOT_ADD_REMOVE_LOG_CHANNEL_ID='0'

# エラーレポートを送信するWebhookのURL（AUTO_ERROR_REPORT_WEBHOOKが設定されている場合は無視されます）。
ERROR_REPORT_WEBHOOK=''

# エラーレポートを自動送信するWebhookのURL。
# 警告: このログにはenvキーやシークレット等の機密情報が含まれる可能性があるため、受信チャンネルは開発者限定にすることを強く推奨。
AUTO_ERROR_REPORT_WEBHOOK=''

# プレイヤーのEmbedカラー（未設定の場合はボットのロール色が使用されます）。
EMBED_COLOR=none

# updateコマンドなどで使用するGitHubリポジトリのURL。
SOURCE_REPO='https://github.com/zRitsu/MuseHeart-MusicBot.git'

# プレフィックス付きテキストコマンドの使用を禁止する。
INTERACTION_COMMAND_ONLY=false

# ボットのプレゼンスを切り替える間隔（秒）。
PRESENCE_INTERVAL=900

# inviteコマンドに招待リンクを追加する追加ボットのID（複数の場合はスペース区切り）。
ADDITIONAL_BOT_IDS=""

# ボットの招待リンクに含める権限のID。
INVITE_PERMISSIONS=332892794064

# ボットのログ・デバッグを有効にする。
ENABLE_LOGGER=false

# gitで使用するデフォルトのディレクトリ。
GIT_DIR="./.git"

#########################
### 音楽システム       ###
#########################

# サーバーでボットのオーディオがミュートになっている場合に警告を表示する。
GUILD_DEAFEN_WARN=true

# Lavalinkサーバーリスト（lavalink.ini）のダウンロードURL。
LAVALINK_SERVER_LIST='https://gist.githubusercontent.com/zRitsu/c3511e1da0440b94c126769dd40c9d91/raw/lavalink.ini'

# Lavalinkサーバーへの再接続試行回数。
LAVALINK_RECONNECT_RETRIES=30

# Deezerの内部クライアントを強制使用する（LavalinkサーバーがDeezerをサポートしている場合でもクライアント側で処理）。
FORCE_USE_DEEZER_CLIENT=false

# ユーザーごとのお気に入り数の上限（0または負の値 = 無制限）。
MAX_USER_FAVS=10

# プレイリスト名の最大文字数。
USER_FAV_MAX_NAME_LENGTH=35

# プレイリストURLの最大文字数。
USER_FAV_MAX_URL_LENGTH=90

# 待機モードで新しい曲を待つ時間（秒）。
IDLE_TIMEOUT=180

# ボイスチャンネルが空になってからメンバーを待つ時間（秒）。
WAIT_FOR_MEMBERS_TIMEOUT=180

# 通常モードのデフォルトプレイヤースキン（スキンファイルをコピーして別名で保存し自由に編集できます。元のスキンのアップデートの影響を受けません）。
DEFAULT_SKIN='default'

# song-requestモードのデフォルトプレイヤースキン（同上）。
DEFAULT_STATIC_SKIN='default'

# 通常モードのスキン一覧から除外するスキン名（.py拡張子なし、複数の場合はスペース区切り）。
IGNORE_SKINS=''

# song-requestモードのスキン一覧から除外するスキン名（.py拡張子なし、複数の場合はスペース区切り）。
IGNORE_STATIC_SKINS=''

# プレイヤーに表示する追加ヒント（改行不可、複数の場合は || 区切り）。
EXTRA_HINTS=""

# プレイヤーでヒントを表示する頻度（値が大きいほど表示頻度が下がります）。
HINT_RATE=4

# voteskipコマンドに必要な投票数。
VOTE_SKIP_AMOUNT=3

# pool_payload_readyイベントのデータクリーンアップ待機時間。
PREFIXED_POOL_TIMEOUT=4

# 音楽追加コマンドでDiscordのURL（および添付ファイル）のサポートを有効にする。
ENABLE_DISCORD_URLS_PLAYBACK=true

# プレイヤー情報をデータベースに保存する間隔（秒、最小30）。
PLAYER_INFO_BACKUP_INTERVAL=45

# MongoDBのレスポンス待機タイムアウト（秒）。
MONGO_TIMEOUT=30

# MongoDBにプレイヤー情報を保存する間隔（秒、最小120）。
PLAYER_INFO_BACKUP_INTERVAL_MONGO=300

# キューに追加できる曲数の上限（0 = 無制限）。
QUEUE_MAX_ENTRIES=0

# 一部のプレフィックスコマンドでdeferを使用する際にtypingを有効にする。
ENABLE_DEFER_TYPING=true

# ボイスチャンネルへの再接続をトリガーする最小Ping値（ms、不安定な状況向け）。
VOICE_CHANNEL_LATENCY_RECONNECT=200

# 内部キャッシュに保存するプレイリスト情報の最大件数。
PLAYLIST_CACHE_SIZE=500

# 内部キャッシュでプレイリスト情報を保持する時間（秒）。
PLAYLIST_CACHE_TTL=1800

# LavalinkサーバーよりもネイティブプロバイダーでのトラックLookupを優先する。
PARTIALTRACK_FIRST=false

# ボットへのメンションで曲リクエストを有効にする。
ENABLE_SONGREQUEST_MENTION=true

##################################################
### 音楽システム - RPC（リッチプレゼンス）     ###
##################################################

# 内部RPCサーバー／Webページを有効にする。
RUN_RPC_SERVER=false

# リッチプレゼンスアプリ用のトークン生成・リンク表示コマンドを有効にする。
ENABLE_RPC_COMMAND=false

# RPCサーバーのURL（メンバーのステータス表示用）。未設定の場合はローカルを使用。
RPC_SERVER='ws://localhost:$PORT/ws'

# /rich_presenceコマンドに表示するURL。
# 未設定の場合はRPC_SERVERのURLが表示されます（RPC_SERVERのURLがメンバーからアクセス可能であれば空欄のままでも可）。
RPC_PUBLIC_URL=''

# RPCへのアクセスにトークン認証を要求する。
ENABLE_RPC_AUTH=false

# YouTubeトラックのskipコマンドのクールダウン（秒）（YTのブロック・意図的なfloodを防ぐため）。
YOUTUBE_TRACK_COOLDOWN=20

##################################################
### 音楽システム - ローカルLavalink設定        ###
##################################################

# ローカルLavalinkサーバーを強制起動する。
# 注意: ボットと同じインスタンスでLavalinkを起動するには最低512MBのRAMが必要です。
# 無効にする場合は以下のLavalink関連設定はすべて無視されます。
RUN_LOCAL_LAVALINK=false

# ローカルLavalinkに接続する。
CONNECT_LOCAL_LAVALINK=true

# 他のプラットフォームで同じ曲を検索する前にYouTubeネイティブ再生を優先する。
PREFER_YOUTUBE_NATIVE_PLAYBACK=true

# ネイティブ再生をサポートする検索プロバイダーのみ登録する。
ONLY_USE_NATIVE_SEARCH_PROVIDERS=true

# デフォルトの検索プロバイダー（複数の場合はスペース区切り、クォートを保持）。
# YouTubeサポートを無効にするには ytsearch または ytmsearch をリストから削除してください。
SEARCH_PROVIDERS="amsearch tdsearch spsearch scsearch ytsearch"

# Lavalinkサーバーの起動を待つ追加の待機時間（秒、現在はほぼ不要のため将来的に廃止予定）。
LAVALINK_ADDITIONAL_SLEEP=0

# Lavalinkサーバープロセスの初期RAM使用量。
LAVALINK_INITIAL_RAM=30

# Lavalinkサーバープロセスが使用するRAMの上限。
LAVALINK_RAM_LIMIT=120

# Lavalinkサーバーが使用するCPUコア数。
LAVALINK_CPU_CORES=1

# Lavalink.jarのダウンロードURL。
LAVALINK_FILE_URL='https://github.com/zRitsu/LL-binaries/releases/download/0.0.1/Lavalink.jar'

# Windowsを除くOSでJavaをインストールするためにjabbaを使用する（jabbaが使えない場合の代替手段）。
USE_JABBA=false

##################################################
### 音楽システム - Last.fm連携                 ###
##################################################

# APIキーの取得: https://www.last.fm/api
LASTFM_KEY=''
LASTFM_SECRET=''

####################################################################################################################
##### ボットのプレゼンス設定:                                                                                  #####
##### 同じタイプで複数のステータスを設定する場合は || で区切ってください。                                    #####
#####                                                                                                          #####
##### プレースホルダー:                                                                                        #####
##### {users}    -> ユーザー数                                                                                 #####
##### {guilds}   -> サーバー数                                                                                 #####
##### {playing}  -> アクティブなプレイヤー数                                                                   #####
##### {uptime}   -> ボットの稼働時間                                                                           #####
##### {owner}    -> ボットのオーナー名（またはチーム名）                                                       #####
#####                                                                                                          #####
##### 以下のプレースホルダーは、カウントが0の場合にそのプレースホルダーを含むテキスト全体が非表示になります。 #####
#####                                                                                                          #####
##### {players_count}                 -> アクティブなプレイヤー数                                             #####
##### {players_count_allbotchannels}  -> 全ボットの全チャンネルのアクティブプレイヤー合計数                   #####
##### {players_count_allbotservers}   -> 全ボットの全サーバーのアクティブプレイヤー合計数（同一サーバーで     #####
#####                                    複数のボットが稼働している場合は重複カウントしない）                  #####
#####                                                                                                          #####
##### 例: {uptime} 稼働中 || {playing} サーバーで音楽を再生中                                                 #####
####################################################################################################################
LISTENING_PRESENCES=''
WATCHING_PRESENCES=''
PLAYING_PRESENCES=''
CUSTOM_STATUS_PRESENCES=''

# ストリーミング形式では名前とURL（TwitchまたはYouTube）を || で区切って指定。
# 複数の設定は ||| で区切ってください。
# 例: コマンドのデモ || https://www.youtube.com/watch?v=OsJYB2W199k ||| Twin Saga || https://www.youtube.com/watch?v=sU-fmPFHzKA
STREAMING_PRESENCES=''

#####################
###### Extras #######
#####################

############################
### Uptime Kuma 監視設定 ###
############################

# Uptime Kuma の Push モニター URL を設定するとハートビートを送信します（省略可）
# 例: https://status.example.com/api/push/xxxxxxxxxx?status=up&msg=OK&ping=
UPTIME_KUMA_PUSH_URL=''
